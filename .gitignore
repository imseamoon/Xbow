# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
.pytest_cache/
# ─── Virtual environment ──────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Model weights (too large for git — use git-lfs or store separately) ─────
model/checkpoints/*.pt
ai/model/checkpoints/*.pt

# ─── Training logs ────────────────────────────────────────
model/checkpoints/logs/
ai/model/checkpoints/logs/

# keep checkpoint metrics and test results
!model/checkpoints/metrics.json
!model/checkpoints/test_results.json

# ─── Raw dataset repos (cloned third-party repos) ─────────
# Processed/split CSVs are tracked instead
dataset/raw/

# ─── Generated inference outputs / reports ────────────────
outputs/*
!outputs/.gitkeep

# ─── Environment / secrets ────────────────────────────────
.env
.env.*
!.env.example

# ─── Editor / OS ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.bak
*.bak.*
.DS_Store
Thumbs.db

# ─── Jupyter ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
!dataset/data_analytics.ipynb

# ─── Node (for when NestJS/Next.js phases begin) ──────────
node_modules/
.next/
dist/

# ─── Coverage reports ─────────────────────────────────────
coverage/
coverage-e2e/
coverage-python/
htmlcov/
.coverage
*.lcov
core/coverage/
core/coverage-e2e/


# ─── Runtime service artifacts ─────────────────────────────
reports/
core/reports/
core/scanner-logs/

.setup.log

# redis dump file
dump.rdb
scanner-logs/
XSStrike/
runs/
output/

# ─── Evaluation archives (generated raw results — NOT tracked) ──
# Each run saves raw fuzzer responses to a timestamped directory.
# Manifests (source of truth) ARE tracked in eval/manifests/.
eval/archive/*
!eval/archive/.gitkeep